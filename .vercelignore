# Local-only Express backend — Vercel uses the api/ directory instead.
# Keeping server/ in the repo is fine (Option A still works locally),
# but we don't want it bundled into the Vercel build.
server/

# Local-only, never deploy
.env
.env.*
!.env.example

# CRA artefacts
build/
coverage/

# Local-only scripts (e.g. items.json updater) — Vercel doesn't run them
scripts/
