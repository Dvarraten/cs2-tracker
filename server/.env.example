# Your 17-digit Steam ID (find it at steamid.io)
STEAM_ID=

# Steam Web API key (get yours at steamcommunity.com/dev/apikey)
STEAM_API_KEY=

# Public URL of the app — used for Steam OpenID realm + callback
# Local dev: http://localhost:3000  |  Production: https://your-app.vercel.app
APP_URL=http://localhost:3000

# Random secret for signing session cookies
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Upstash Redis (from your Upstash console -> REST API tab)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Express server port (default 3001)
PORT=3001
CORS_ORIGIN=http://localhost:3000
POLL_INTERVAL_MIN=5
