# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# Your SteamID64. The big number from steamcommunity.com/profiles/<here>.
# Inventory must be set to "Public" in Steam privacy settings.
STEAM_ID=76561198133541811

# Port the local backend listens on. Frontend expects 3001 by default.
PORT=3001

# How often (in minutes) to poll Steam for inventory changes.
POLL_INTERVAL_MIN=5

# Allowed origin for the React dev server. Adjust if your frontend runs elsewhere.
CORS_ORIGIN=http://localhost:3000
